# -------------------------------------------------------
# Football Betting Pipeline — Environment Configuration
# Copy this file to .env and fill in the required values.
# Never commit .env to version control.
# -------------------------------------------------------

# ----------------------------
# Required
# ----------------------------

# API key for The Odds API (https://the-odds-api.com)
ODDS_API_KEY=your_odds_api_key_here

# ----------------------------
# Optional — defaults shown
# ----------------------------

# Path to the SQLite ledger database file
DB_PATH=ledger.db

# Minimum hours before kickoff to include a fixture
MIN_LEAD_HOURS=2

# Maximum hours before kickoff to include a fixture
MAX_LEAD_HOURS=48

# Flat stake per bet in GBP (used until bankroll management is implemented)
FLAT_STAKE=10.0

# Minimum synthesiser confidence to recommend a back
CONFIDENCE_THRESHOLD=0.60

# Logging level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# Path to leagues configuration YAML (default: config/leagues.yaml)
BETTING_LEAGUES_CONFIG=config/leagues.yaml

# Path to markets configuration YAML (default: config/markets.yaml)
BETTING_MARKETS_CONFIG=config/markets.yaml

# Local directory for caching football-data.co.uk CSV files
CSV_CACHE_DIR=.csv_cache

# Hours before a cached CSV is considered stale and re-downloaded
CSV_MAX_AGE_HOURS=24

# Profiles replace the old PAPER_TRADING toggle.
# The active profile is managed via the dashboard or API.
# PAPER_TRADING is no longer used.

# Scheduler cron hours (UTC)
# Adjust for your timezone and target kickoff windows.
# UK evening kickoffs (18:00-20:45 BST): analysis_hour=14 gives comfortable buffer in summer.
# All times are UTC — subtract 0 (GMT/winter) or 1 (BST/summer) for UK local time.
BACKUP_HOUR=4
MORNING_HOUR=8
SNAPSHOT_HOUR=12
ANALYSIS_HOUR=16

# ----------------------------
# Oracle Object Storage — only needed for local dev
# On Oracle Cloud VM, instance principal auth is used instead
# ----------------------------

OCI_NAMESPACE=your_namespace
OCI_BUCKET=betting-backups
# OCI_CONFIG_FILE=~/.oci/config   # local dev only

# ----------------------------
# Fixture calendar
# ----------------------------

# How many days ahead to fetch fixtures in the weekly refresh
CALENDAR_LOOKAHEAD_DAYS=7

# Hour (UTC) to run the weekly calendar refresh on Sundays
CALENDAR_REFRESH_HOUR=20
